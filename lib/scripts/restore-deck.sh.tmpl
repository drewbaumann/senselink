#!/bin/bash
# SenseLink — restore script for SteamOS updates.
#
# SteamOS updates can replace /etc and /usr, wiping the systemd unit and
# the usbip binary. Run this after a SteamOS update to put everything
# back from the survival copy in $HOME.
#
# Templated: __INSTALL_DIR__ is replaced with the user's home install dir.

set -euo pipefail

INSTALL_DIR="__INSTALL_DIR__"
BIN_DIR="$INSTALL_DIR/bin"

err() { echo "ERROR: $*" >&2; exit 1; }

[[ -x "$BIN_DIR/usbip"  ]] || err "missing $BIN_DIR/usbip"
[[ -x "$BIN_DIR/usbipd" ]] || err "missing $BIN_DIR/usbipd"
[[ -f "$INSTALL_DIR/senselink-server.service" ]] || err "missing service template"
[[ -f "$INSTALL_DIR/99-senselink-dualsense.rules" ]] || err "missing udev rule"
[[ -f "$INSTALL_DIR/on-plug.sh" ]] || err "missing on-plug helper"

echo "==> Reinstalling usbip binaries to /usr/bin"
sudo steamos-readonly disable
sudo install -m 0755 "$BIN_DIR/usbip"  /usr/bin/usbip
sudo install -m 0755 "$BIN_DIR/usbipd" /usr/bin/usbipd
sudo steamos-readonly enable

echo "==> Reinstalling systemd unit"
sudo install -m 0644 "$INSTALL_DIR/senselink-server.service" \
  /etc/systemd/system/senselink-server.service

echo "==> Reinstalling udev rule"
sudo install -m 0644 "$INSTALL_DIR/99-senselink-dualsense.rules" \
  /etc/udev/rules.d/99-senselink-dualsense.rules

echo "==> Reinstalling udev helper"
sudo install -d -m 0755 /etc/senselink
sudo install -m 0755 "$INSTALL_DIR/on-plug.sh" /etc/senselink/on-plug.sh

echo "==> Reloading systemd + udev"
sudo systemctl daemon-reload
sudo systemctl enable --now senselink-server.service
sudo udevadm control --reload-rules
sudo udevadm trigger

echo "==> Restored."
