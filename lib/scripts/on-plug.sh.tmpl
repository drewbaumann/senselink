#!/bin/bash
# SenseLink — udev helper that binds the DualSense to usbip when plugged in.
# Templated: __BINDIR__ is replaced with the absolute path to the usbip binary
# directory at install time.
BUSID="$1"
LOG=/var/log/senselink.log

{
  echo "[$(date -Iseconds)] on-plug: binding $BUSID"
  __BINDIR__/usbip bind --busid="$BUSID" 2>&1
} >> "$LOG"
