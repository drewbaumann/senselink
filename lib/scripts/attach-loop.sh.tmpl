#!/bin/bash
# SenseLink — runs on the host. Continuously tries to find a DualSense
# exported by the Deck's usbipd, attaches it, and waits. Re-attaches on
# disconnect or network blips.
#
# Templated: __DECK_HOST__ is replaced with the Deck's hostname at install
# time. Override at runtime by setting SENSELINK_DECK in the environment
# (useful for testing).

set -u

DECK_HOST="${SENSELINK_DECK:-__DECK_HOST__}"
LOG=/var/log/senselink.log

log() {
  printf '[%s] attach-loop: %s\n' "$(date -Iseconds)" "$*" | tee -a "$LOG"
}

# DualSense USB IDs (standard + Edge)
DUALSENSE_VIDPID="054c:0ce6 054c:0df2"

# Returns busid of the first matching DualSense exported by $DECK_HOST,
# or empty string if none found.
find_dualsense() {
  local listing
  listing=$(usbip list -r "$DECK_HOST" 2>/dev/null) || return 1
  # `usbip list -r` lines:
  #   1-1.4: Sony Corp. : DualSense Wireless Controller (054c:0ce6)
  while IFS= read -r line; do
    for vidpid in $DUALSENSE_VIDPID; do
      if [[ "$line" == *"($vidpid)"* ]]; then
        # busid is everything before the first colon-space
        local busid="${line%%:*}"
        busid="${busid## }"
        echo "$busid"
        return 0
      fi
    done
  done <<< "$listing"
  return 1
}

# Returns 0 if a vhci port is currently attached.
attached_count() {
  usbip port 2>/dev/null | grep -c "Port [0-9]*: <Port in Use>" || true
}

main() {
  log "starting; deck=$DECK_HOST"
  while true; do
    if (( $(attached_count) > 0 )); then
      sleep 5
      continue
    fi
    busid=$(find_dualsense || true)
    if [[ -n "${busid:-}" ]]; then
      log "found DualSense at $busid; attaching"
      if usbip attach -r "$DECK_HOST" -b "$busid" 2>>"$LOG"; then
        log "attached"
      else
        log "attach failed; will retry"
        sleep 5
      fi
    else
      sleep 5
    fi
  done
}

main "$@"
